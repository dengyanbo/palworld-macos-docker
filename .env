# =====================================================================
#  幻兽帕鲁 (Palworld) 专用服务器配置  ——  适用于 macOS + Docker
#  说明：本文件每一行均为「键=值」，修改后重新 ./setup.sh restart 生效
#  完整可用参数见镜像文档：
#  https://github.com/thijsvanloef/palworld-server-docker
# =====================================================================

# ---------- 基础设置 ----------
TZ=Asia/Shanghai
PUID=1000
PGID=1000
PLAYERS=16
PORT=8211
MULTITHREADING=true

# ---------- 服务器信息 ----------
SERVER_NAME=My Palworld Server
SERVER_DESCRIPTION=Palworld server on macOS via Docker

# ⚠️ 首次使用务必修改下面两个密码！
SERVER_PASSWORD=CHANGE_ME_player_password
ADMIN_PASSWORD=CHANGE_ME_admin_password

# 是否在社区服列表中公开（公开时强烈建议设置 SERVER_PASSWORD）
COMMUNITY=false

# 跨平台联机（保留默认即可）
CROSSPLAY_PLATFORMS=(Steam,Xbox,PS5,Mac)

# ---------- 启动 / 更新 ----------
UPDATE_ON_BOOT=true        # 启动时通过 steamcmd 检查并更新服务端
AUTO_UPDATE_ENABLED=false  # 定时自动更新（需要时设为 true）
AUTO_UPDATE_CRON_EXPRESSION=0 * * * *
AUTO_UPDATE_WARN_MINUTES=30

# ---------- 自动备份 ----------
BACKUP_ENABLED=true
BACKUP_CRON_EXPRESSION=0 0 * * *   # 每天 0 点备份
DELETE_OLD_BACKUPS=false
OLD_BACKUP_DAYS=30

# ---------- RCON（远程控制台，可选） ----------
RCON_ENABLED=false
RCON_PORT=25575
QUERY_PORT=27015

# ---------- REST API（默认开启，勿对公网暴露 8212） ----------
REST_API_ENABLED=true
REST_API_PORT=8212

# ---------- 玩家日志 ----------
ENABLE_PLAYER_LOGGING=true
PLAYER_LOGGING_POLL_PERIOD=5

# =====================================================================
#  常用玩法倍率（可按喜好调整，值为浮点字符串）
# =====================================================================
DIFFICULTY=None
DEATH_PENALTY=All
EXP_RATE=1.000000
PAL_CAPTURE_RATE=1.000000
PAL_SPAWN_NUM_RATE=1.000000
PLAYER_DAMAGE_RATE_ATTACK=1.000000
PLAYER_DAMAGE_RATE_DEFENSE=1.000000
COLLECTION_DROP_RATE=1.000000
ENEMY_DROP_ITEM_RATE=1.000000
DAYTIME_SPEEDRATE=1.000000
NIGHTTIME_SPEEDRATE=1.000000
WORK_SPEED_RATE=1.000000
AUTO_SAVE_SPAN=30.000000
IS_PVP=False
ENABLE_PLAYER_TO_PLAYER_DAMAGE=False
GUILD_PLAYER_MAX_NUM=20
BASE_CAMP_MAX_NUM=128
BASE_CAMP_WORKER_MAX_NUM=15

# =====================================================================
#  Box64 调优（仅对 Apple 芯片 / ARM64 宿主机生效）
#  若服务端频繁崩溃，可逐项调高稳定性（代价是性能下降）：
#    STRONGMEM 可设 2 或 3（3 最稳）；其余可在 0/1/2 间调整
# =====================================================================
BOX64_DYNAREC_STRONGMEM=1
BOX64_DYNAREC_BIGBLOCK=1
BOX64_DYNAREC_SAFEFLAGS=1
BOX64_DYNAREC_FASTROUND=1
BOX64_DYNAREC_FASTNAN=1
BOX64_DYNAREC_X87DOUBLE=0
